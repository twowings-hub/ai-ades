# ============================================================
# AI-ADES 환경변수 템플릿 (.env로 복사 후 값 채우기)
# ============================================================

# ---- LLM ----
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:14b
CLAUDE_API_KEY=
OPENAI_API_KEY=

# ---- PostgreSQL (pm-postgres 컨테이너, ai-internal 네트워크) ----
POSTGRES_HOST=pm-postgres
POSTGRES_PORT=5432
POSTGRES_DB=ades_db
POSTGRES_USER=ades
POSTGRES_PASSWORD=changeme

# ---- InfluxDB ----
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=changeme
INFLUXDB_ORG=ades
INFLUXDB_BUCKET=laser_process

# ---- MLflow ----
MLFLOW_TRACKING_URI=http://mlflow:5000

# ---- Qdrant (qdrant 컨테이너, ai-internal 네트워크) ----
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_PREFIX=ades_

# ---- 포트 (호스트 노출) ----
DATA_PREP_PORT=8010
MODELING_PORT=8011
EXECUTION_PORT=8012
FRONTEND_PORT=5173
GRAFANA_PORT=3010
INFLUXDB_PORT=8086
MLFLOW_PORT=5000
KAFKA_PORT=9092

# ---- 공정 판정 기준 (절대 변경 금지) ----
DEPTH_OK_MIN=0.0
DEPTH_OK_MAX=25.0

# ---- 환경 ----
ENV=development
GPU_ENABLED=false

# ---- Docker 외부 네트워크 ----
EXTERNAL_NETWORK=ai-internal
