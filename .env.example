# ============================================================
# AI-ADES 환경변수 템플릿 (.env로 복사 후 값 채우기)
# ============================================================

# ---- LLM ----
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:14b
CLAUDE_API_KEY=
OPENAI_API_KEY=

# ---- PostgreSQL (pm-postgres 컨테이너, ai-internal 네트워크) ----
POSTGRES_HOST=pm-postgres
POSTGRES_PORT=5432
POSTGRES_DB=ades_db
POSTGRES_USER=ades
POSTGRES_PASSWORD=changeme

# ---- InfluxDB ----
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=changeme
INFLUXDB_ORG=ades
INFLUXDB_BUCKET=laser_process

# ---- MLflow ----
MLFLOW_TRACKING_URI=http://mlflow:5000

# ---- Qdrant (qdrant 컨테이너, ai-internal 네트워크) ----
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_PREFIX=ades_

# ---- 포트 (호스트 노출) ----
DATA_PREP_PORT=8010
MODELING_PORT=8011
EXECUTION_PORT=8012
FRONTEND_PORT=5173
GRAFANA_PORT=3010
INFLUXDB_PORT=8086
MLFLOW_PORT=5000
KAFKA_PORT=9092

# ---- 공정 판정 기준 (절대 변경 금지) ----
DEPTH_OK_MIN=0.0
DEPTH_OK_MAX=25.0

# ---- Auto DOE 탐색 공간 (절대 변경 금지, 콤마 구분) ----
SEARCH_SPACE_SPEED=200,500,1000
SEARCH_SPACE_DEFOCUS=0,1,2,3,4
SEARCH_SPACE_FREQUENCY=100,200
SEARCH_SPACE_POWER_MIN=2.8
SEARCH_SPACE_POWER_MAX=59.8

# ---- 서비스 간 호출 URL ----
MODELING_AGENT_URL=http://modeling-agent:8011
EXECUTION_AGENT_URL=http://execution-agent:8012

# ---- Phase 6: 자동 재학습 트리거 (experiments 누적 건수 기준) ----
AUTO_RETRAIN_THRESHOLD=50

# ---- Phase 6: Plasma 센서 시계열 파싱 ----
PLASMA_M1_END_S=0.02
PLASMA_M2_END_S=0.07
PLASMA_EXPECTED_DURATION_S=0.1
PLASMA_TIME_TOLERANCE_S=0.005
PLASMA_DETECT_THRESHOLD=5.0
PLASMA_DOWNSAMPLE_FACTOR=100

# ---- 환경 ----
ENV=development
GPU_ENABLED=false

# ---- Docker 외부 네트워크 ----
EXTERNAL_NETWORK=ai-internal
